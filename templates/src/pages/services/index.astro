---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import { Icon } from 'astro-icon/components';
import { business } from '../../data/business';
import { serviceTypes } from '../../data/serviceTypes';
import { serviceUrl, contactUrl } from '../../lib/urls';
---

<BaseLayout
  title={`Plumbing Services | ${business.name}`}
  description={`${business.name} offers a full range of residential and commercial plumbing services across ${business.serviceRadius}. From leak repair to new construction, we handle it all.`}
>
  <Breadcrumbs crumbs={[{ label: 'Services' }]} />

  <!-- ============ HEADER ============ -->
  <section class="py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="max-w-3xl animate-fade-up">
        <h1 class="font-display text-4xl text-brand-900 sm:text-5xl">
          Our Plumbing Services
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-stone-600">
          Whether you need an emergency repair at midnight or a planned remodel for your home,
          {business.name} provides comprehensive plumbing solutions for residential and commercial
          properties throughout {business.serviceRadius}.
        </p>
      </div>
    </div>
  </section>

  <!-- ============ SERVICES GRID ============ -->
  <section class="pb-16 lg:pb-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {serviceTypes.map((service, i) => (
          <a
            href={serviceUrl(service.slug)}
            class={`card-hover group relative rounded-xl border border-stone-200 bg-white p-6 animate-fade-up stagger-${Math.min(i + 1, 6)}`}
          >
            {service.emergency && (
              <span class="absolute right-4 top-4 inline-flex items-center gap-1 rounded-full bg-amber-100 px-2 py-0.5 text-[11px] font-semibold text-amber-700">
                <Icon name="lucide:zap" class="size-3" />
                24/7
              </span>
            )}
            <div class="flex size-12 items-center justify-center rounded-lg bg-brand-50 text-brand-700 transition-colors group-hover:bg-brand-100">
              <Icon name={service.icon} class="size-6" />
            </div>
            <h2 class="mt-4 font-display text-lg text-brand-900">
              {service.name}
            </h2>
            <p class="mt-2 text-sm leading-relaxed text-stone-600">
              {service.shortDescription}
            </p>
            <div class="mt-4 flex items-center justify-between">
              <span class="text-sm font-semibold text-brand-700">
                From ${service.priceRange.min}
              </span>
              <span class="text-xs text-stone-400">
                Up to ${service.priceRange.max.toLocaleString()}
              </span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="bg-brand-900">
    <div class="mx-auto max-w-7xl px-5 py-12 lg:px-8 lg:py-16">
      <div class="flex flex-col items-center gap-6 text-center sm:flex-row sm:justify-between sm:text-left">
        <div>
          <h2 class="font-display text-3xl text-white">Not Sure What You Need?</h2>
          <p class="mt-2 text-brand-200">
            Call us and describe the issue. We will help you figure out the right service and provide an honest estimate.
          </p>
        </div>
        <div class="flex shrink-0 flex-wrap gap-4">
          <a
            href={business.phoneHref}
            class="inline-flex items-center gap-2 rounded-lg bg-amber-500 px-6 py-3 text-sm font-semibold text-brand-950 shadow-lg transition-all hover:bg-amber-400"
          >
            <Icon name="lucide:phone" class="size-5" />
            {business.phone}
          </a>
          <a
            href={contactUrl()}
            class="inline-flex items-center gap-2 rounded-lg border border-white/20 bg-white/10 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-white/20"
          >
            Request a Quote
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
