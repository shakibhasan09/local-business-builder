---
import { Icon } from 'astro-icon/components';
import { business, yearsInBusiness } from '../../data/business';
import { serviceTypes } from '../../data/serviceTypes';
import { serviceAreas, getAreaBySlug, getNearbyAreas } from '../../data/serviceAreas';
import { serviceUrl, areaUrl, comboUrl, contactUrl } from '../../lib/urls';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumbs from '../../components/Breadcrumbs.astro';
import SeoFaq from '../../components/SeoFaq.astro';
import SeoTestimonials from '../../components/SeoTestimonials.astro';

import type { ServiceArea } from '../../data/serviceAreas';

export function getStaticPaths() {
  return serviceAreas.map((area) => ({
    params: { area: area.slug },
    props: { area },
  }));
}

interface Props {
  area: ServiceArea;
}

const { area } = Astro.props;

const nearbyAreas = getNearbyAreas(area);

const pageTitle = `Plumber in ${area.name}, TX`;
const metaDescription = `Licensed plumber serving ${area.name}, ${area.county}, TX. ${area.responseTime} response time. Residential and commercial plumbing services including repairs, installations, and emergencies. Call ${business.phone}.`;

// Build LocalBusiness schema
const schema = {
  '@context': 'https://schema.org',
  '@type': 'Plumber',
  name: business.name,
  description: `${business.name} provides licensed residential and commercial plumbing services in ${area.name}, ${area.county}, Texas.`,
  telephone: business.phone,
  url: business.website,
  address: {
    '@type': 'PostalAddress',
    addressLocality: area.name,
    addressRegion: 'TX',
    postalCode: area.zipCodes[0],
    addressCountry: 'US',
  },
  geo: {
    '@type': 'GeoCoordinates',
    latitude: area.lat,
    longitude: area.lng,
  },
  areaServed: [
    {
      '@type': 'City',
      name: area.name,
    },
    {
      '@type': 'AdministrativeArea',
      name: area.county,
    },
  ],
  openingHoursSpecification: business.hours.map((h) => ({
    '@type': 'OpeningHoursSpecification',
    dayOfWeek: h.days,
    opens: h.hours === 'Closed' ? undefined : '08:00',
    closes: h.hours === 'Closed' ? undefined : '17:00',
  })),
  priceRange: '$$',
};
---

<BaseLayout title={pageTitle} description={metaDescription} schema={schema}>
  <Breadcrumbs
    crumbs={[
      { label: 'Service Areas', href: '/areas/' },
      { label: area.name },
    ]}
  />

  <!-- Hero section -->
  <section class="mx-auto max-w-7xl px-5 pb-12 pt-8 lg:px-8">
    <div class="grid gap-8 lg:grid-cols-3 lg:gap-12">
      {/* Main content */}
      <div class="lg:col-span-2">
        <h1 class="font-display text-3xl text-brand-900 sm:text-4xl lg:text-5xl">
          {pageTitle}
        </h1>

        <p class="mt-6 text-lg leading-relaxed text-stone-600">
          {area.description}
        </p>

        <p class="mt-4 text-stone-600">
          {business.name} has proudly served {area.name} and {area.county} for over {yearsInBusiness()} years.
          Whether you need emergency leak repair, a water heater replaced, or a complete repipe for an older home,
          our licensed plumbers deliver reliable, honest work at fair prices. We know this community because we are
          part of it.
        </p>
      </div>

      {/* Quick facts sidebar */}
      <div class="lg:col-span-1">
        <div class="rounded-xl border border-stone-200/60 bg-white p-6 shadow-sm">
          <h2 class="text-sm font-semibold uppercase tracking-wide text-stone-400">
            Quick Facts
          </h2>

          <dl class="mt-4 space-y-4">
            <div>
              <dt class="text-xs font-medium uppercase tracking-wide text-stone-400">County</dt>
              <dd class="mt-0.5 text-sm font-semibold text-stone-800">{area.county}</dd>
            </div>

            <div>
              <dt class="text-xs font-medium uppercase tracking-wide text-stone-400">Population</dt>
              <dd class="mt-0.5 text-sm font-semibold text-stone-800">
                {area.population.toLocaleString()}
              </dd>
            </div>

            <div>
              <dt class="text-xs font-medium uppercase tracking-wide text-stone-400">ZIP Codes</dt>
              <dd class="mt-0.5 text-sm font-semibold text-stone-800">
                {area.zipCodes.join(', ')}
              </dd>
            </div>

            <div>
              <dt class="text-xs font-medium uppercase tracking-wide text-stone-400">Response Time</dt>
              <dd class="mt-0.5 flex items-center gap-1.5 text-sm font-semibold text-brand-700">
                <Icon name="lucide:clock" class="size-4 text-brand-500" />
                {area.responseTime}
              </dd>
            </div>
          </dl>

          <div class="mt-6 border-t border-stone-100 pt-5">
            <a
              href={business.phoneHref}
              class="flex w-full items-center justify-center gap-2 rounded-lg bg-brand-800 px-4 py-2.5 text-sm font-medium text-white transition-colors hover:bg-brand-700"
            >
              <Icon name="lucide:phone" class="size-4" />
              {business.phone}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Services available in this area -->
  <section class="border-t border-stone-200/60 bg-white py-16">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <h2 class="font-display text-2xl text-brand-900 sm:text-3xl">
        Services Available in {area.name}
      </h2>
      <p class="mt-3 max-w-2xl text-stone-600">
        Our licensed plumbers handle everything from routine maintenance to complex installations.
        Select a service below for details and pricing specific to {area.name}.
      </p>

      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {serviceTypes.map((service) => (
          <a
            href={comboUrl(area.slug, service.slug)}
            class="group rounded-xl border border-stone-200/60 bg-stone-50 p-5 transition-all hover:border-brand-200 hover:bg-white hover:shadow-md"
          >
            <div class="flex items-center justify-between">
              <Icon name={service.icon} class="size-6 text-brand-600" />
              {service.emergency && (
                <span class="rounded-full bg-red-50 px-2 py-0.5 text-[10px] font-semibold uppercase tracking-wide text-red-600 ring-1 ring-red-200/60">
                  Emergency
                </span>
              )}
            </div>

            <h3 class="mt-3 text-base font-semibold text-stone-800 group-hover:text-brand-800">
              {service.name}
            </h3>

            <p class="mt-1.5 text-sm leading-relaxed text-stone-500">
              {service.shortDescription}
            </p>

            <p class="mt-3 text-xs font-medium text-brand-700">
              ${service.priceRange.min.toLocaleString()} - ${service.priceRange.max.toLocaleString()}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Nearby areas -->
  {nearbyAreas.length > 0 && (
    <section class="mx-auto max-w-7xl px-5 py-16 lg:px-8">
      <h2 class="font-display text-2xl text-brand-900 sm:text-3xl">
        Nearby Areas We Serve
      </h2>
      <p class="mt-3 max-w-2xl text-stone-600">
        In addition to {area.name}, our service area covers these nearby communities.
      </p>

      <div class="mt-8 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {nearbyAreas.map((nearby) => (
          <a
            href={areaUrl(nearby.slug)}
            class="group rounded-xl border border-stone-200/60 bg-white p-5 transition-all hover:border-brand-200 hover:shadow-md"
          >
            <div class="flex items-center gap-3">
              <Icon name="lucide:map-pin" class="size-5 text-brand-500" />
              <span class="font-semibold text-stone-800 group-hover:text-brand-800">
                {nearby.name}
              </span>
            </div>
            <p class="mt-2 text-sm text-stone-500">
              {nearby.county}
            </p>
            <p class="mt-1 text-xs text-stone-400">
              Population: {nearby.population.toLocaleString()}
            </p>
          </a>
        ))}
      </div>
    </section>
  )}

  <!-- FAQ section -->
  <div class="border-t border-stone-200/60 bg-white">
    <SeoFaq area={area} />
  </div>

  <!-- Testimonials section -->
  <div class="mx-auto max-w-7xl px-5 lg:px-8">
    <SeoTestimonials area={area} />
  </div>

  <!-- CTA section -->
  <section class="mt-16 bg-brand-900 py-16">
    <div class="mx-auto max-w-4xl px-5 text-center lg:px-8">
      <h2 class="font-display text-2xl text-white sm:text-3xl">
        Need a Plumber in {area.name}?
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-brand-200">
        {business.name} is locally owned and licensed ({business.license}).
        We have been serving {area.county} and the surrounding area since {business.yearEstablished}.
        Call us today for prompt, professional plumbing service.
      </p>
      <div class="mt-8 flex flex-col items-center justify-center gap-4 sm:flex-row">
        <a
          href={business.phoneHref}
          class="inline-flex items-center gap-2 rounded-lg bg-white px-6 py-3 text-sm font-semibold text-brand-900 shadow-sm transition-all hover:bg-stone-100 hover:shadow-md"
        >
          <Icon name="lucide:phone" class="size-4" />
          {business.phone}
        </a>
        <a
          href={contactUrl()}
          class="inline-flex items-center gap-2 rounded-lg border border-brand-300/40 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-brand-800"
        >
          <Icon name="lucide:mail" class="size-4" />
          Request a Quote
        </a>
      </div>
    </div>
  </section>
</BaseLayout>
