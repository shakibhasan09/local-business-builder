---
import BaseLayout from '../layouts/BaseLayout.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { Icon } from 'astro-icon/components';
import { business, yearsInBusiness } from '../data/business';
import { serviceAreas } from '../data/serviceAreas';
import { areaUrl, contactUrl } from '../lib/urls';

const years = yearsInBusiness();
---

<BaseLayout
  title={`About ${business.name} | Brenham TX Plumber`}
  description={`Learn about ${business.name}, founded by ${business.owner} in ${business.yearEstablished}. ${years}+ years serving ${business.serviceRadius} with licensed, insured plumbing services.`}
>
  <Breadcrumbs crumbs={[{ label: 'About' }]} />

  <!-- ============ HEADER ============ -->
  <section class="py-12 lg:py-16">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="max-w-3xl animate-fade-up">
        <h1 class="font-display text-4xl text-brand-900 sm:text-5xl">
          About {business.name}
        </h1>
        <p class="mt-4 text-lg leading-relaxed text-stone-600">
          Locally owned, licensed, and insured. We have been solving plumbing problems across
          Central Texas since {business.yearEstablished}.
        </p>
      </div>
    </div>
  </section>

  <!-- ============ OUR STORY ============ -->
  <section class="pb-16 lg:pb-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <div class="grid gap-12 lg:grid-cols-2 lg:gap-16">
        <!-- Story content -->
        <div class="prose-editorial">
          <h2>Our Story</h2>
          <p>
            {business.name} was founded by {business.owner} in {business.yearEstablished}
            with a straightforward goal: provide honest, high-quality plumbing services to
            the communities of {business.serviceRadius}.
          </p>
          <p>
            What started as a one-man operation has grown into a trusted local plumbing company
            with over {years} years of experience. Aaron holds a Texas Master Plumber license
            and personally oversees every project to make sure the work meets his standards.
          </p>
          <p>
            We believe in doing the job right the first time, charging fair prices, and treating
            every home like our own. That approach has earned us an A+ rating with the Better
            Business Bureau and a loyal base of repeat customers across the region.
          </p>
          <p>
            Whether it is a midnight emergency or a planned kitchen remodel, we show up on time,
            explain the situation clearly, and get to work. No surprises, no upselling, just
            reliable plumbing from people you can trust.
          </p>
        </div>

        <!-- Owner spotlight -->
        <div>
          <div class="rounded-xl border border-stone-200 bg-white p-8">
            <div class="flex items-center gap-4">
              <div class="flex size-16 items-center justify-center rounded-full bg-brand-100">
                <Icon name="lucide:user" class="size-8 text-brand-700" />
              </div>
              <div>
                <h3 class="font-display text-xl text-brand-900">{business.owner}</h3>
                <p class="text-sm text-stone-500">Owner & Master Plumber</p>
              </div>
            </div>
            <div class="mt-6 space-y-3 text-sm leading-relaxed text-stone-600">
              <p>
                Aaron Roshto has been working in the plumbing trade for over {years} years.
                After earning his Texas Master Plumber license, he founded {business.name}
                to serve the Brenham area and surrounding communities with the kind of
                personalized service that larger companies cannot match.
              </p>
              <p>
                He is hands-on with every project, from the initial estimate to the final
                quality check. When you call {business.name}, there is a good chance Aaron
                will be the one answering the phone.
              </p>
            </div>
            <div class="mt-6 border-t border-stone-100 pt-6">
              <p class="text-xs font-medium uppercase tracking-wider text-stone-400">Credentials</p>
              <div class="mt-2 flex flex-wrap gap-2">
                <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-50 px-3 py-1 text-xs font-medium text-brand-700">
                  <Icon name="lucide:badge-check" class="size-3.5" />
                  {business.license}
                </span>
                <span class="inline-flex items-center gap-1.5 rounded-full bg-brand-50 px-3 py-1 text-xs font-medium text-brand-700">
                  <Icon name="lucide:shield-check" class="size-3.5" />
                  BBB A+ Rated
                </span>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ============ TRUST SIGNALS ============ -->
  <section class="bg-stone-100 py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <h2 class="text-center font-display text-3xl text-brand-900">
        Why Customers Trust Us
      </h2>

      <div class="mt-12 grid gap-6 sm:grid-cols-2 lg:grid-cols-4">
        {[
          {
            icon: 'lucide:badge-check',
            title: 'Licensed',
            detail: business.license,
          },
          {
            icon: 'lucide:shield',
            title: 'Fully Insured',
            detail: 'Liability insurance and workers\' compensation coverage on every job.',
          },
          {
            icon: 'lucide:award',
            title: 'BBB A+ Rating',
            detail: 'Consistently rated A+ by the Better Business Bureau for ethical business practices.',
          },
          {
            icon: 'lucide:calendar',
            title: `${years}+ Years in Business`,
            detail: `Serving ${business.serviceRadius} since ${business.yearEstablished}.`,
          },
        ].map((item, i) => (
          <div class={`rounded-xl border border-stone-200 bg-white p-6 animate-fade-up stagger-${i + 1}`}>
            <div class="flex size-12 items-center justify-center rounded-lg bg-brand-50 text-brand-700">
              <Icon name={item.icon} class="size-6" />
            </div>
            <h3 class="mt-4 font-display text-lg text-brand-900">{item.title}</h3>
            <p class="mt-2 text-sm leading-relaxed text-stone-600">{item.detail}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ AREAS WE COVER ============ -->
  <section class="py-16 lg:py-24">
    <div class="mx-auto max-w-7xl px-5 lg:px-8">
      <h2 class="text-center font-display text-3xl text-brand-900">
        Communities We Serve
      </h2>
      <p class="mx-auto mt-4 max-w-2xl text-center text-stone-600">
        We provide plumbing services to every corner of {business.serviceRadius}.
        Here are the communities where we are most active.
      </p>

      <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        {serviceAreas.map((area) => (
          <a
            href={areaUrl(area.slug)}
            class="card-hover flex items-center gap-3 rounded-xl border border-stone-200 bg-white px-5 py-4 transition-colors"
          >
            <Icon name="lucide:map-pin" class="size-5 shrink-0 text-brand-600" />
            <div>
              <span class="font-medium text-brand-900">{area.name}</span>
              <span class="block text-xs text-stone-500">{area.county}</span>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- ============ CTA ============ -->
  <section class="bg-brand-900">
    <div class="mx-auto max-w-7xl px-5 py-12 lg:px-8 lg:py-16">
      <div class="flex flex-col items-center gap-6 text-center sm:flex-row sm:justify-between sm:text-left">
        <div>
          <h2 class="font-display text-3xl text-white">Ready to Work With Us?</h2>
          <p class="mt-2 text-brand-200">
            Call today for a free estimate or send us a message online. We look forward to earning your trust.
          </p>
        </div>
        <div class="flex shrink-0 flex-wrap gap-4">
          <a
            href={business.phoneHref}
            class="inline-flex items-center gap-2 rounded-lg bg-amber-500 px-6 py-3 text-sm font-semibold text-brand-950 shadow-lg transition-all hover:bg-amber-400"
          >
            <Icon name="lucide:phone" class="size-5" />
            {business.phone}
          </a>
          <a
            href={contactUrl()}
            class="inline-flex items-center gap-2 rounded-lg border border-white/20 bg-white/10 px-6 py-3 text-sm font-semibold text-white transition-all hover:bg-white/20"
          >
            Contact Us
          </a>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>
