---
import type { ServiceArea } from '../data/serviceAreas';
import type { ServiceType } from '../data/serviceTypes';
import { serviceAreas } from '../data/serviceAreas';
import { comboUrl, areaUrl } from '../lib/urls';

interface Props {
  currentArea: ServiceArea;
  service?: ServiceType;
}

const { currentArea, service } = Astro.props;

// All areas except the current one
const otherAreas = serviceAreas.filter((a) => a.slug !== currentArea.slug);
---

<section class="mt-12">
  <h3 class="text-sm font-semibold uppercase tracking-wide text-stone-400">
    {service
      ? `${service.name} in other areas`
      : 'Other areas we serve'}
  </h3>

  <div class="mt-4 grid gap-3 sm:grid-cols-2 lg:grid-cols-3">
    {otherAreas.map((area) => (
      <a
        href={service ? comboUrl(area.slug, service.slug) : areaUrl(area.slug)}
        class="group rounded-xl border border-stone-200/60 bg-white p-5 transition-all hover:border-brand-200 hover:shadow-md"
      >
        <span class="font-semibold text-stone-800 group-hover:text-brand-800">
          {area.name}
        </span>
        <p class="mt-1 text-sm text-stone-500">
          {area.county}
        </p>
      </a>
    ))}
  </div>
</section>
